# ─── Supabase（サーバーサイド） ────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Supabase（クライアントサイド・web ページ用） ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─── アプリ URL ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://bukken.io
# 開発時:
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Government APIs（無料・要申請） ─────────────────────────────────────────
REINFOLIB_API_KEY=        # 不動産情報ライブラリ（申請中）
# J-SHIS・国土地理院は申請不要

# ─── Third party APIs ─────────────────────────────────────────────────────────
FUDOSAN_DB_API_KEY=       # FUDOSAN DB（要更新申請）
SERP_API_KEY=             # SerpAPI（クロスプラットフォーム検索）

# ─── 大島てる ──────────────────────────────────────────────────────────────────
OSHIMA_DRY_RUN=true       # 許諾前は true のまま（本番許可後に false に変更）

# ─── Extension（Plasmo public env） ──────────────────────────────────────────
PLASMO_PUBLIC_API_URL=https://api.bukken.io
PLASMO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
PLASMO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# 開発時:
# PLASMO_PUBLIC_API_URL=http://localhost:3000
